{
  "name": "simulate-cribbage-games",
  "version": "0.0.3",
  "description": "Play a cribbage hand between two opponents.",
  "targets": {
    "default": {
      "context": "browser",
      "distDir": "dist"
    }
  },
  "dependencies": {
    "md5": "^2.3.0",
    "parcel": "^2.0.0-nightly.634",
    "postcss": "^8.2.9",
    "random-js": "^2.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typed-css-modules": "^0.9.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.1",
    "@types/jest": "^30.0.0",
    "@types/md5": "^2.3.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.0",
    "@types/yargs": "^17.0.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "cspell": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.25.1",
    "events": "^3.3.0",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "postcss-modules": "^6.0.1",
    "process": "^0.11.10",
    "react-helmet": "^6.1.0",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.1.0",
    "typescript": "^6.0.3",
    "vm-browserify": "^1.1.2"
  },
  "scripts": {
    "test": "jest --testPathPatterns='.*\\.spec\\.ts$'",
    "coverage": "jest --testPathPatterns='.*\\.spec\\.ts$' --collectCoverage --collectCoverageFrom='src/**/*.{js,jsx,ts,tsx}' --collectCoverageFrom='!**/*.css.d.ts'",
    "tcm-build": "tcm src/",
    "tcm-watch": "tcm --watch src/",
    "tcm-clean": "rm -f src/*.module.css.d.ts src/*/*.module.css.d.ts",
    "start": "parcel serve src/index.html",
    "start-clean": "rm -f .parcel-cache/ dist/",
    "build-simulation": "npm run tcm-build && npm run tsc-build",
    "build-webapp": "parcel build src/index.html",
    "build-webapp-clean": "rm -f index.html index.*.js index.*.js.map index.*.css index.*.css.map",
    "serve": "http-server",
    "tsc-build": "tsc --jsx react",
    "tsc-watch": "tsc --jsx react --watch",
    "tsc-clean": "rm -f src/*.js src/cribbage/*.js src/components/*.js test/*.js",
    "clean": "rm -rf src/*.module.css.d.ts src/*/*.module.css.d.ts .parcel-cache/ dist/ index.html index.*.js index.*.js.map index.*.css index.*.css.map src/*.js src/cribbage/*.js src/components/*.js",
    "simulate": "node dist/src/simulateCribbageHands.js --hide-pone-hand --hide-dealer-hand --hide-play-actions",
    "cpd": "pmd --version | grep -q 'PMD 7' && (find src test -type f -name \"*.ts\" > cpd-files.txt && pmd cpd --language typescript --minimum-tokens 40 --file-list cpd-files.txt && rm -f cpd-files.txt) || pmd cpd --language ecmascript --minimum-tokens 22 --files $(find src test -type f -name \"*.ts\")",
    "eslint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "spellcheck": "cspell --config cspell.json"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Mark Fitzgerald <mark.a.fitzgerald1@gmail.com> (https://github.com/markafitzgerald1)",
  "license": "MPL-2.0"
}
